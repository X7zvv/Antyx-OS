#!/usr/bin/env bash
set -u

green="\033[1;32m"
yellow="\033[1;33m"
red="\033[1;31m"
reset="\033[0m"

ok()   { printf "${green}[OK]${reset} %s\n" "$1"; }
warn() { printf "${yellow}[INFO]${reset} %s\n" "$1"; }
bad()  { printf "${red}[WARNUNG]${reset} %s\n" "$1"; }

echo "Antyx-OS Sicherheitscheck"
echo "========================="

if command -v getenforce >/dev/null 2>&1; then
    mode="$(getenforce)"
    if [[ "$mode" == "Enforcing" ]]; then ok "SELinux: Enforcing"; else bad "SELinux: $mode"; fi
else
    bad "SELinux-Status konnte nicht gelesen werden."
fi

if systemctl is-active --quiet firewalld 2>/dev/null; then
    ok "Firewall: firewalld aktiv"
else
    bad "Firewall ist nicht aktiv."
fi

if command -v mokutil >/dev/null 2>&1; then
    sb="$(mokutil --sb-state 2>/dev/null || true)"
    if grep -qi "enabled" <<<"$sb"; then ok "Secure Boot: aktiviert"; else warn "Secure Boot: ${sb:-unbekannt}"; fi
else
    warn "mokutil nicht verfügbar; Secure-Boot-Status nicht geprüft."
fi

if findmnt -no SOURCE / 2>/dev/null | grep -qE 'crypt|mapper'; then
    ok "Systemlaufwerk scheint verschlüsselt zu sein."
else
    warn "Verschlüsselung konnte nicht eindeutig erkannt werden."
fi

if systemctl is-enabled --quiet sshd 2>/dev/null; then
    warn "SSH-Server ist aktiviert. Nur eingeschaltet lassen, wenn du ihn brauchst."
else
    ok "SSH-Server ist standardmäßig nicht aktiviert."
fi

echo
echo "System-Image:"
rpm-ostree status 2>/dev/null | sed -n '1,12p' || true
