#!/usr/bin/env bash
set -u

green="\033[1;32m"
yellow="\033[1;33m"
red="\033[1;31m"
reset="\033[0m"

ok()   { printf "${green}[OK]${reset} %s\n" "$1"; }
warn() { printf "${yellow}[INFO]${reset} %s\n" "$1"; }
bad()  { printf "${red}[WARNING]${reset} %s\n" "$1"; }

echo "Antyx-OS Security Check"
echo "======================="

if command -v getenforce >/dev/null 2>&1; then
    mode="$(getenforce)"
    if [[ "$mode" == "Enforcing" ]]; then ok "SELinux: Enforcing"; else bad "SELinux: $mode"; fi
else
    bad "Unable to read SELinux status."
fi

if systemctl is-active --quiet firewalld 2>/dev/null; then
    ok "Firewall: firewalld active"
else
    bad "Firewall is not active."
fi

if command -v mokutil >/dev/null 2>&1; then
    sb="$(mokutil --sb-state 2>/dev/null || true)"
    if grep -qi "enabled" <<<"$sb"; then ok "Secure Boot: enabled"; else warn "Secure Boot: ${sb:-unknown}"; fi
else
    warn "mokutil is unavailable; Secure Boot status was not checked."
fi

if findmnt -no SOURCE / 2>/dev/null | grep -qE 'crypt|mapper'; then
    ok "The system drive appears to be encrypted."
else
    warn "Disk encryption could not be confirmed."
fi

if systemctl is-enabled --quiet sshd 2>/dev/null; then
    warn "The SSH server is enabled. Leave it enabled only when required."
else
    ok "The SSH server is not enabled by default."
fi

echo
echo "System image:"
rpm-ostree status 2>/dev/null | sed -n '1,12p' || true
