#!/usr/bin/env bash
set -u

if command -v fastfetch >/dev/null 2>&1; then
    fastfetch
else
    cat /etc/os-release
    echo
    uname -a
fi

echo
echo "Antyx commands:"
echo "  antyx-check   Check system security status"
echo "  antyx-update  Update the system and Flatpaks"
echo "  antyx-info    Show system information"
