#!/usr/bin/env bash
set -uo pipefail

PASS=0
WARN=0
FAIL=0

ok()   { printf '  [OK]   %s\n' "$1"; PASS=$((PASS + 1)); }
warn() { printf '  [WARN] %s\n' "$1"; WARN=$((WARN + 1)); }
fail() { printf '  [FAIL] %s\n' "$1"; FAIL=$((FAIL + 1)); }

printf '\nAntyx-OS 0.4 verification\n\n'

grep -q '^ID=antyx$' /etc/os-release 2>/dev/null &&
  ok 'Antyx OS identity' || fail 'Antyx OS identity'

command -v steam >/dev/null 2>&1 &&
  ok 'Steam installed' || fail 'Steam missing'

command -v antyx-hub >/dev/null 2>&1 &&
  ok 'Antyx Hub installed' || fail 'Antyx Hub missing'

desktop-file-validate /usr/share/applications/antyx-hub.desktop >/dev/null 2>&1 &&
  ok 'Antyx Hub desktop entry' || fail 'Antyx Hub desktop entry is invalid'

[[ "$(plymouth-set-default-theme 2>/dev/null)" == 'antyx' ]] &&
  ok 'Antyx Plymouth active' || warn 'Antyx Plymouth not active'

grep -q '^Current=antyx$' /etc/sddm.conf.d/99-antyx-theme.conf 2>/dev/null &&
  ok 'Antyx SDDM configured' || fail 'Antyx SDDM configuration missing'

[[ -x /usr/libexec/antyx-fastfetch ]] &&
  ok 'Antyx Fastfetch wrapper' || fail 'Antyx Fastfetch wrapper missing'

for app in \
  com.brave.Browser \
  com.modrinth.ModrinthApp \
  com.discordapp.Discord \
  com.spotify.Client; do
  if flatpak --system info "$app" >/dev/null 2>&1; then
    ok "$app installed"
  else
    warn "$app is pending first-boot Flatpak provisioning"
  fi
done

VISIBLE_BAZZITE=0
for directory in /usr/share/applications /etc/xdg/autostart; do
  [[ -d "$directory" ]] || continue
  while IFS= read -r -d '' desktop; do
    case "$(basename "$desktop")" in
      antyx-*) continue ;;
    esac
    if grep -qiE 'bazzite|ublue-os|universal blue' "$desktop" &&
       ! grep -q '^NoDisplay=true$' "$desktop"; then
      printf '  [FAIL] Visible upstream launcher: %s\n' "$desktop"
      VISIBLE_BAZZITE=1
      FAIL=$((FAIL + 1))
    fi
  done < <(find "$directory" -maxdepth 2 -type f -name '*.desktop' -print0)
done
[[ "$VISIBLE_BAZZITE" -eq 0 ]] && ok 'No visible Bazzite launchers'

VISIBLE_ASSETS="$(find \
  /usr/share/backgrounds \
  /usr/share/wallpapers \
  /usr/share/plymouth/themes \
  /usr/share/sddm/themes \
  -maxdepth 5 \( -iname '*bazzite*' -o -iname '*ublue*' \) \
  -print 2>/dev/null | head -n 1)"

[[ -z "$VISIBLE_ASSETS" ]] &&
  ok 'No visible Bazzite visual assets' ||
  warn "Remaining upstream asset: $VISIBLE_ASSETS"

printf '\nResult: %d OK, %d warnings, %d failures\n' "$PASS" "$WARN" "$FAIL"
[[ "$FAIL" -eq 0 ]]
